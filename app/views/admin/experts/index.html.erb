<div class="flex justify-between items-center mb-8">
  <h1 class="text-2xl font-bold text-gray-900"><%= t("admin.experts") %></h1>
  <%= link_to t("admin.new_expert"), new_admin_expert_path, class: "bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition" %>
</div>

<div class="bg-white rounded-lg shadow-sm overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("activerecord.attributes.expert.name") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("activerecord.attributes.expert.city") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("activerecord.attributes.expert.email") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.status") %></th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.actions") %></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @experts.each do |expert| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <% if expert.photo.attached? %>
                <%= image_tag expert.photo, class: "h-10 w-10 rounded-full object-cover" %>
              <% else %>
                <div class="h-10 w-10 rounded-full bg-orange-500 flex items-center justify-center text-white font-semibold">
                  <%= expert.name.first.upcase %>
                </div>
              <% end %>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-900"><%= expert.name %></div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= expert.city %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= expert.email %></td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= expert.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
              <%= expert.active? ? 'Aktivny' : 'Neaktivny' %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to t("admin.edit"), edit_admin_expert_path(expert), class: "text-orange-600 hover:text-orange-900 mr-4" %>
            <%= link_to t("admin.delete"), admin_expert_path(expert), data: { turbo_method: :delete, turbo_confirm: t("admin.confirm_delete") }, class: "text-red-600 hover:text-red-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
