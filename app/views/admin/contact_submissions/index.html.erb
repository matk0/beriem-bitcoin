<h1 class="text-2xl font-bold text-gray-900 mb-8"><%= t("admin.submissions") %></h1>

<div class="mb-6 flex space-x-2">
  <%= link_to "Vsetky", admin_contact_submissions_path, class: "px-4 py-2 rounded-lg #{params[:status].blank? ? 'bg-orange-500 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
  <% ContactSubmission::STATUSES.each do |status| %>
    <%= link_to t("submission_status.#{status}"), admin_contact_submissions_path(status: status), class: "px-4 py-2 rounded-lg #{params[:status] == status ? 'bg-orange-500 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow-sm overflow-hidden">
  <% if @submissions.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("activerecord.attributes.contact_submission.sender_name") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Expert</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.status") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.created_at") %></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @submissions.each do |submission| %>
          <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= admin_contact_submission_path(submission) %>'">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= submission.sender_name %></div>
              <div class="text-sm text-gray-500"><%= submission.sender_email %></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= submission.expert&.name || "Vseobecny kontakt" %>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= submission.status == 'new' ? 'bg-orange-100 text-orange-800' : submission.status == 'replied' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= t("submission_status.#{submission.status}") %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= l(submission.created_at, format: :short) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="p-6 text-gray-500">Zatial ziadne spravy.</p>
  <% end %>
</div>
