<% content_for :title, @expert.name %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-6">
    <%= link_to t("common.back"), experts_path, class: "text-orange-500 hover:text-orange-600" %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="md:flex">
      <div class="md:w-1/3">
        <% if @expert.photo.attached? %>
          <%= image_tag @expert.photo, class: "w-full h-64 md:h-full object-cover" %>
        <% else %>
          <div class="w-full h-64 md:h-full bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center">
            <span class="text-6xl font-bold text-white"><%= @expert.name.first.upcase %></span>
          </div>
        <% end %>
      </div>
      <div class="md:w-2/3 p-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @expert.name %></h1>
        <p class="text-xl text-orange-500 mb-6"><%= @expert.city %></p>

        <% if @expert.bio.present? %>
          <div class="prose prose-orange mb-8">
            <p><%= simple_format(@expert.bio) %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-12 bg-white rounded-xl shadow-sm border border-gray-100 p-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-6"><%= t("contact.expert_contact_title", expert_name: @expert.name) %></h2>
    <%= render "contact_submissions/form", contact_submission: @contact_submission, url: expert_contact_submissions_path(@expert) %>
  </div>
</div>
