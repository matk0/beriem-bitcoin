<% content_for :title, t("experts.title") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="text-center mb-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= t("experts.title") %></h1>
    <p class="text-xl text-gray-600"><%= t("experts.subtitle") %></p>
  </div>

  <% if @cities.present? %>
    <div class="mb-8 flex flex-wrap justify-center gap-2">
      <%= link_to t("experts.all_cities"), experts_path, class: "px-4 py-2 rounded-full #{params[:city].blank? ? 'bg-orange-500 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
      <% @cities.each do |city| %>
        <%= link_to city, experts_path(city: city), class: "px-4 py-2 rounded-full #{params[:city] == city ? 'bg-orange-500 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
      <% end %>
    </div>
  <% end %>

  <% if @experts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @experts.each do |expert| %>
        <%= link_to expert_path(expert), class: "block bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition" do %>
          <div class="aspect-w-16 aspect-h-9 bg-gray-100">
            <% if expert.photo.attached? %>
              <%= image_tag expert.photo, class: "w-full h-48 object-cover" %>
            <% else %>
              <div class="w-full h-48 bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center">
                <span class="text-4xl font-bold text-white"><%= expert.name.first.upcase %></span>
              </div>
            <% end %>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-1"><%= expert.name %></h3>
            <p class="text-orange-500 mb-3"><%= expert.city %></p>
            <% if expert.bio.present? %>
              <p class="text-gray-600 line-clamp-2"><%= truncate(expert.bio, length: 100) %></p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-600"><%= t("experts.no_experts") %></p>
    </div>
  <% end %>
</div>
