<!DOCTYPE html>
<html lang="sk">
  <head>
    <title>Admin - <%= t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-100">
    <div class="flex">
      <aside class="w-64 min-h-screen bg-gray-800 text-white">
        <div class="p-4">
          <%= link_to admin_root_path, class: "flex items-center space-x-2" do %>
            <span class="text-2xl font-bold text-orange-500">B</span>
            <span class="font-semibold">Admin</span>
          <% end %>
        </div>

        <nav class="mt-4">
          <%= link_to admin_root_path, class: "flex items-center px-4 py-3 hover:bg-gray-700 transition #{request.path == admin_root_path ? 'bg-gray-700' : ''}" do %>
            <svg class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <%= t("admin.dashboard") %>
          <% end %>

          <%= link_to admin_experts_path, class: "flex items-center px-4 py-3 hover:bg-gray-700 transition #{request.path.start_with?(admin_experts_path) ? 'bg-gray-700' : ''}" do %>
            <svg class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
            </svg>
            <%= t("admin.experts") %>
          <% end %>

          <%= link_to admin_contact_submissions_path, class: "flex items-center px-4 py-3 hover:bg-gray-700 transition #{request.path.start_with?(admin_contact_submissions_path) ? 'bg-gray-700' : ''}" do %>
            <svg class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <%= t("admin.submissions") %>
          <% end %>
        </nav>

        <div class="absolute bottom-0 w-64 p-4 border-t border-gray-700">
          <%= link_to root_path, class: "flex items-center text-gray-400 hover:text-white mb-2" do %>
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Web
          <% end %>
          <%= button_to destroy_admin_session_path, method: :delete, class: "flex items-center text-gray-400 hover:text-white w-full text-left", form: { class: "inline" } do %>
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <%= t("nav.logout") %>
          <% end %>
        </div>
      </aside>

      <main class="flex-1 p-8">
        <% if notice %>
          <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-6">
            <p class="text-green-700"><%= notice %></p>
          </div>
        <% end %>

        <% if alert %>
          <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
            <p class="text-red-700"><%= alert %></p>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
