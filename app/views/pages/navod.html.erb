<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-6">
    <%= link_to t("common.back"), navody_path, class: "text-orange-500 hover:text-orange-600" %>
  </div>

  <article class="prose prose-lg prose-orange max-w-none">
    <%= @content[:body] %>
  </article>
</div>
